#!/usr/bin/env bash
#MISE description="開発環境のAWSインフラストラクチャをsynthする"
#MISE depends=["frontend:build"]
#MISE dir="infra"

stack_name="$(
  awk -F= '
    $0 !~ /^[[:space:]]*#/ && $1 == "STACK_NAME" {
      sub(/^[^=]*=/, "")
      gsub(/^[[:space:]]+|[[:space:]]+$/, "")
      gsub(/^["'\''"]|["'\''"]$/, "")
      print
      exit
    }
  ' .env
)"

if [[ -z "$stack_name" ]]; then
  echo "infra設定のSTACK_NAMEが未設定です" >&2
  exit 1
fi

pnpm cdk synth "$stack_name"
