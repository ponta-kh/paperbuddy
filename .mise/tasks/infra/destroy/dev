#!/usr/bin/env bash
#MISE description="開発環境のPaperBuddy本体AWSリソースとCDK bootstrap資産を削除する"

set -euo pipefail

readonly ENV_FILE="infra/.env"
readonly BOOTSTRAP_STACK_NAME="CDKToolkit"
readonly STACK_SNAPSHOT_FILE="$(mktemp /tmp/paperbuddy-stack.XXXXXX.json)"
readonly STACK_RESOURCES_FILE="$(mktemp /tmp/paperbuddy-stack-resources.XXXXXX.json)"
readonly BOOTSTRAP_SNAPSHOT_FILE="$(mktemp /tmp/paperbuddy-bootstrap-stack.XXXXXX.json)"

cleanup() {
  rm -f "$STACK_SNAPSHOT_FILE" "$STACK_RESOURCES_FILE" "$BOOTSTRAP_SNAPSHOT_FILE"
}
trap cleanup EXIT

read_env_value() {
  local key="$1"
  local value

  value="$(
    awk -F= -v key="$key" '
      $0 !~ /^[[:space:]]*#/ && $1 == key {
        sub(/^[^=]*=/, "")
        gsub(/^[[:space:]]+|[[:space:]]+$/, "")
        gsub(/^["'\''"]|["'\''"]$/, "")
        print
        exit
      }
    ' "$ENV_FILE"
  )"

  if [[ -z "$value" ]]; then
    echo "infra設定の${key}が未設定です" >&2
    exit 1
  fi

  printf '%s' "$value"
}

output_value() {
  local key="$1"

  jq -r --arg key "$key" \
    '.Stacks[0].Outputs[]? | select(.OutputKey == $key) | .OutputValue' \
    "$STACK_SNAPSHOT_FILE"
}

bootstrap_output_value() {
  local key="$1"

  jq -r --arg key "$key" \
    '.Stacks[0].Outputs[]? | select(.OutputKey == $key) | .OutputValue' \
    "$BOOTSTRAP_SNAPSHOT_FILE"
}

stack_resource_ids_by_type() {
  local resource_type="$1"

  jq -r --arg resource_type "$resource_type" '
    .StackResourceSummaries[]
    | select(.ResourceType == $resource_type)
    | .PhysicalResourceId
  ' "$STACK_RESOURCES_FILE"
}

require_command() {
  local command_name="$1"

  if ! command -v "$command_name" >/dev/null 2>&1; then
    echo "必要なコマンドが見つかりません: ${command_name}" >&2
    exit 1
  fi
}

empty_s3_bucket_completely() {
  local bucket_name="$1"
  local delete_payload
  local object_count

  echo "S3バケットを空にします: ${bucket_name}"
  if ! aws s3api head-bucket --bucket "$bucket_name" >/dev/null 2>&1; then
    echo "S3バケットは存在しないためスキップします: ${bucket_name}"
    return
  fi

  aws s3 rm "s3://${bucket_name}" --recursive --region "$AWS_REGION"

  while true; do
    delete_payload="$(
      aws s3api list-object-versions \
        --bucket "$bucket_name" \
        --region "$AWS_REGION" \
        --max-items 1000 \
        --output json \
      | jq -c '{
          Objects: (
            [.Versions[]?, .DeleteMarkers[]?]
            | map({Key: .Key, VersionId: .VersionId})
          ),
          Quiet: true
        }'
    )"

    object_count="$(jq '.Objects | length' <<< "$delete_payload")"
    [[ "$object_count" -eq 0 ]] && break

    aws s3api delete-objects \
      --bucket "$bucket_name" \
      --region "$AWS_REGION" \
      --delete "$delete_payload" \
      > /dev/null
  done
}

delete_dynamodb_table() {
  local table_name="$1"

  [[ -z "$table_name" || "$table_name" == "null" ]] && return

  if ! aws dynamodb describe-table \
    --table-name "$table_name" \
    --region "$AWS_REGION" \
    >/dev/null 2>&1; then
    echo "DynamoDBテーブルは存在しないためスキップします: ${table_name}"
    return
  fi

  echo "DynamoDBテーブルを削除します: ${table_name}"
  aws dynamodb update-table \
    --table-name "$table_name" \
    --region "$AWS_REGION" \
    --no-deletion-protection-enabled \
    > /dev/null

  until [[ "$(
    aws dynamodb describe-table \
      --table-name "$table_name" \
      --region "$AWS_REGION" \
      --query 'Table.TableStatus' \
      --output text
  )" == "ACTIVE" ]]; do
    sleep 5
  done

  aws dynamodb delete-table \
    --table-name "$table_name" \
    --region "$AWS_REGION" \
    > /dev/null

  aws dynamodb wait table-not-exists \
    --table-name "$table_name" \
    --region "$AWS_REGION"
}

delete_s3_bucket() {
  local bucket_name="$1"

  [[ -z "$bucket_name" || "$bucket_name" == "null" ]] && return

  if ! aws s3api head-bucket --bucket "$bucket_name" >/dev/null 2>&1; then
    echo "S3バケットは存在しないためスキップします: ${bucket_name}"
    return
  fi

  empty_s3_bucket_completely "$bucket_name"
  echo "S3バケットを削除します: ${bucket_name}"
  aws s3api delete-bucket \
    --bucket "$bucket_name" \
    --region "$AWS_REGION"
}

delete_log_group() {
  local log_group_name="$1"

  [[ -z "$log_group_name" || "$log_group_name" == "null" ]] && return

  echo "CloudWatch Logsロググループを削除します: ${log_group_name}"
  aws logs delete-log-group \
    --log-group-name "$log_group_name" \
    --region "$AWS_REGION" \
    || true
}

delete_ecr_repository_images() {
  local repository_name="$1"
  local image_ids
  local image_count

  [[ -z "$repository_name" || "$repository_name" == "null" ]] && return

  if ! aws ecr describe-repositories \
    --repository-names "$repository_name" \
    --region "$AWS_REGION" \
    >/dev/null 2>&1; then
    echo "ECRリポジトリは存在しないためスキップします: ${repository_name}"
    return
  fi

  echo "ECRイメージを削除します: ${repository_name}"
  while true; do
    image_ids="$(
      aws ecr list-images \
        --repository-name "$repository_name" \
        --region "$AWS_REGION" \
        --query 'imageIds[0:100]' \
        --output json
    )"
    image_count="$(jq 'length' <<< "$image_ids")"
    [[ "$image_count" -eq 0 ]] && break

    aws ecr batch-delete-image \
      --repository-name "$repository_name" \
      --region "$AWS_REGION" \
      --image-ids "$image_ids" \
      > /dev/null
  done
}

delete_bootstrap_resources() {
  local bootstrap_bucket_name
  local bootstrap_repository_name

  if ! aws cloudformation describe-stacks \
    --stack-name "$BOOTSTRAP_STACK_NAME" \
    --region "$AWS_REGION" \
    --output json \
    > "$BOOTSTRAP_SNAPSHOT_FILE" 2>/dev/null; then
    echo "CDK bootstrapスタックは存在しないためスキップします: ${BOOTSTRAP_STACK_NAME}"
    return
  fi

  bootstrap_bucket_name="$(bootstrap_output_value BucketName)"
  bootstrap_repository_name="$(bootstrap_output_value ImageRepositoryName)"

  echo
  echo "CDK bootstrap資産を削除します"
  printf 'BOOTSTRAP_STACK_NAME=%s\n' "$BOOTSTRAP_STACK_NAME"
  printf 'BOOTSTRAP_BUCKET_NAME=%s\n' "$bootstrap_bucket_name"
  printf 'BOOTSTRAP_REPOSITORY_NAME=%s\n' "$bootstrap_repository_name"

  delete_s3_bucket "$bootstrap_bucket_name"
  delete_ecr_repository_images "$bootstrap_repository_name"

  echo "CDK bootstrapスタックを削除します: ${BOOTSTRAP_STACK_NAME}"
  aws cloudformation delete-stack \
    --stack-name "$BOOTSTRAP_STACK_NAME" \
    --region "$AWS_REGION"

  aws cloudformation wait stack-delete-complete \
    --stack-name "$BOOTSTRAP_STACK_NAME" \
    --region "$AWS_REGION"
}

audit_deleted_resources() {
  echo
  echo "削除結果を監査します"

  if aws cloudformation describe-stacks \
    --stack-name "$STACK_NAME" \
    --region "$AWS_REGION" \
    >/dev/null 2>&1; then
    echo "スタックがまだ存在します: ${STACK_NAME}" >&2
    exit 1
  fi

  for table_name in "$CHAT_TABLE_NAME" "$LIBRARY_TABLE_NAME"; do
    if aws dynamodb describe-table \
      --table-name "$table_name" \
      --region "$AWS_REGION" \
      >/dev/null 2>&1; then
      echo "DynamoDBテーブルがまだ存在します: ${table_name}" >&2
      exit 1
    fi
  done

  for bucket_name in "$FRONTEND_BUCKET_NAME" "$RAG_SOURCE_BUCKET_NAME"; do
    if aws s3api head-bucket --bucket "$bucket_name" >/dev/null 2>&1; then
      echo "S3バケットがまだ存在します: ${bucket_name}" >&2
      exit 1
    fi
  done

  if aws cognito-idp describe-user-pool \
    --user-pool-id "$USER_POOL_ID" \
    --region "$AWS_REGION" \
    >/dev/null 2>&1; then
    echo "Cognito User Poolがまだ存在します: ${USER_POOL_ID}" >&2
    exit 1
  fi

  remaining_tagged_resources="$(
    aws resourcegroupstaggingapi get-resources \
      --region "$AWS_REGION" \
      --tag-filters Key=aws:cloudformation:stack-name,Values="$STACK_NAME" \
      --query 'ResourceTagMappingList[].ResourceARN' \
      --output text
  )"

  if [[ -n "$remaining_tagged_resources" ]]; then
    echo "PaperBuddyスタックタグが残るリソースがあります:" >&2
    printf '%s\n' "$remaining_tagged_resources" >&2
    exit 1
  fi

  echo "PaperBuddy本体リソースの削除を確認しました"
}

audit_bootstrap_deleted() {
  local bootstrap_bucket_name="$1"
  local bootstrap_repository_name="$2"

  echo
  echo "CDK bootstrap資産の削除結果を監査します"

  if aws cloudformation describe-stacks \
    --stack-name "$BOOTSTRAP_STACK_NAME" \
    --region "$AWS_REGION" \
    >/dev/null 2>&1; then
    echo "CDK bootstrapスタックがまだ存在します: ${BOOTSTRAP_STACK_NAME}" >&2
    exit 1
  fi

  if [[ -n "$bootstrap_bucket_name" && "$bootstrap_bucket_name" != "null" ]] \
    && aws s3api head-bucket --bucket "$bootstrap_bucket_name" >/dev/null 2>&1; then
    echo "CDK bootstrap S3バケットがまだ存在します: ${bootstrap_bucket_name}" >&2
    exit 1
  fi

  if [[ -n "$bootstrap_repository_name" && "$bootstrap_repository_name" != "null" ]] \
    && aws ecr describe-repositories \
      --repository-names "$bootstrap_repository_name" \
      --region "$AWS_REGION" \
      >/dev/null 2>&1; then
    echo "CDK bootstrap ECRリポジトリがまだ存在します: ${bootstrap_repository_name}" >&2
    exit 1
  fi

  echo "CDK bootstrap資産の削除を確認しました"
}

require_command aws
require_command jq

if [[ ! -f "$ENV_FILE" ]]; then
  echo "infra設定ファイルが見つかりません: ${ENV_FILE}" >&2
  echo "infra/.env.example を infra/.env にコピーして値を設定してください。" >&2
  exit 1
fi

STACK_NAME="$(read_env_value STACK_NAME)"
AWS_REGION="$(read_env_value AWS_REGION)"

aws cloudformation describe-stacks \
  --stack-name "$STACK_NAME" \
  --region "$AWS_REGION" \
  --output json \
  > "$STACK_SNAPSHOT_FILE" 2>/dev/null \
  || printf '{"Stacks":[{"Outputs":[]}]}\n' > "$STACK_SNAPSHOT_FILE"

if aws cloudformation list-stack-resources \
  --stack-name "$STACK_NAME" \
  --region "$AWS_REGION" \
  --output json \
  > "$STACK_RESOURCES_FILE" 2>/dev/null; then
  stack_exists="true"
else
  printf '{"StackResourceSummaries":[]}\n' > "$STACK_RESOURCES_FILE"
  stack_exists="false"
fi

CHAT_TABLE_NAME="$(output_value ChatTableName)"
LIBRARY_TABLE_NAME="$(output_value LibraryTableName)"
FRONTEND_BUCKET_NAME="$(output_value FrontendBucketName)"
RAG_SOURCE_BUCKET_NAME="$(output_value RagSourceBucketName)"
USER_POOL_ID="$(output_value UserPoolId)"
BOOTSTRAP_BUCKET_NAME=""
BOOTSTRAP_REPOSITORY_NAME=""
if aws cloudformation describe-stacks \
  --stack-name "$BOOTSTRAP_STACK_NAME" \
  --region "$AWS_REGION" \
  --output json \
  > "$BOOTSTRAP_SNAPSHOT_FILE" 2>/dev/null; then
  BOOTSTRAP_BUCKET_NAME="$(bootstrap_output_value BucketName)"
  BOOTSTRAP_REPOSITORY_NAME="$(bootstrap_output_value ImageRepositoryName)"
fi
LOG_GROUP_NAMES=()
while IFS= read -r log_group_name; do
  [[ -z "$log_group_name" ]] && continue
  LOG_GROUP_NAMES+=("$log_group_name")
done < <(stack_resource_ids_by_type "AWS::Logs::LogGroup")

echo "以下のPaperBuddy本体AWSリソースとCDK bootstrap資産を削除します。削除後は復元できません。"
echo "AWSアカウント:"
aws sts get-caller-identity
echo
printf 'AWS_REGION=%s\n' "$AWS_REGION"
printf 'STACK_NAME=%s\n' "$STACK_NAME"
printf 'STACK_EXISTS=%s\n' "$stack_exists"
printf 'CHAT_TABLE_NAME=%s\n' "$CHAT_TABLE_NAME"
printf 'LIBRARY_TABLE_NAME=%s\n' "$LIBRARY_TABLE_NAME"
printf 'FRONTEND_BUCKET_NAME=%s\n' "$FRONTEND_BUCKET_NAME"
printf 'RAG_SOURCE_BUCKET_NAME=%s\n' "$RAG_SOURCE_BUCKET_NAME"
printf 'USER_POOL_ID=%s\n' "$USER_POOL_ID"
printf 'LOG_GROUP_NAMES=%s\n' "${LOG_GROUP_NAMES[*]:-}"
printf 'BOOTSTRAP_STACK_NAME=%s\n' "$BOOTSTRAP_STACK_NAME"
printf 'BOOTSTRAP_BUCKET_NAME=%s\n' "$BOOTSTRAP_BUCKET_NAME"
printf 'BOOTSTRAP_REPOSITORY_NAME=%s\n' "$BOOTSTRAP_REPOSITORY_NAME"
echo
read -r -p "削除を続行するにはスタック名 ${STACK_NAME} を入力してください: " confirmation

if [[ "$confirmation" != "$STACK_NAME" ]]; then
  echo "入力が一致しないため削除を中止しました" >&2
  exit 1
fi

if [[ "$stack_exists" == "true" ]]; then
  echo "CloudFormationスタックを削除します: ${STACK_NAME}"
  aws cloudformation delete-stack \
    --stack-name "$STACK_NAME" \
    --region "$AWS_REGION"

  aws cloudformation wait stack-delete-complete \
    --stack-name "$STACK_NAME" \
    --region "$AWS_REGION"
else
  echo "CloudFormationスタックは存在しないためスキップします: ${STACK_NAME}"
fi

delete_dynamodb_table "$CHAT_TABLE_NAME"
delete_dynamodb_table "$LIBRARY_TABLE_NAME"
delete_s3_bucket "$FRONTEND_BUCKET_NAME"
delete_s3_bucket "$RAG_SOURCE_BUCKET_NAME"

if [[ -n "$USER_POOL_ID" && "$USER_POOL_ID" != "null" ]]; then
  echo "Cognito User Poolを削除します: ${USER_POOL_ID}"
  aws cognito-idp delete-user-pool \
    --user-pool-id "$USER_POOL_ID" \
    --region "$AWS_REGION"
fi

for log_group_name in "${LOG_GROUP_NAMES[@]}"; do
  delete_log_group "$log_group_name"
done

if [[ "$stack_exists" == "true" ]]; then
  audit_deleted_resources
fi

delete_bootstrap_resources
audit_bootstrap_deleted "$BOOTSTRAP_BUCKET_NAME" "$BOOTSTRAP_REPOSITORY_NAME"

echo
echo "PaperBuddy本体AWSリソースとCDK bootstrap資産を削除しました。"
