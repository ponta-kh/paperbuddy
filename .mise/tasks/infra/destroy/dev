#!/usr/bin/env bash
#MISE description="開発環境のPaperBuddy本体AWSリソースを完全削除する"

set -euo pipefail

readonly ENV_FILE="infra/.env"
readonly STAGE_NAME="dev"
readonly RESOURCE_NAME_PREFIX="paperbuddy-${STAGE_NAME}"
readonly STACK_SNAPSHOT_FILE="$(mktemp /tmp/paperbuddy-stack.XXXXXX.json)"
readonly STACK_RESOURCES_FILE="$(mktemp /tmp/paperbuddy-stack-resources.XXXXXX.json)"

cleanup() {
  rm -f "$STACK_SNAPSHOT_FILE" "$STACK_RESOURCES_FILE"
}
trap cleanup EXIT

read_env_value() {
  local key="$1"
  local value

  value="$(
    awk -F= -v key="$key" '
      $0 !~ /^[[:space:]]*#/ && $1 == key {
        sub(/^[^=]*=/, "")
        gsub(/^[[:space:]]+|[[:space:]]+$/, "")
        gsub(/^["'\''"]|["'\''"]$/, "")
        print
        exit
      }
    ' "$ENV_FILE"
  )"

  if [[ -z "$value" ]]; then
    echo "infra設定の${key}が未設定です" >&2
    exit 1
  fi

  printf '%s' "$value"
}

output_value() {
  local key="$1"

  jq -r --arg key "$key" \
    '.Stacks[0].Outputs[]? | select(.OutputKey == $key) | .OutputValue' \
    "$STACK_SNAPSHOT_FILE"
}

stack_resource_ids_by_type() {
  local resource_type="$1"

  jq -r --arg resource_type "$resource_type" '
    .StackResourceSummaries[]
    | select(.ResourceType == $resource_type)
    | .PhysicalResourceId
  ' "$STACK_RESOURCES_FILE"
}

require_command() {
  local command_name="$1"

  if ! command -v "$command_name" >/dev/null 2>&1; then
    echo "必要なコマンドが見つかりません: ${command_name}" >&2
    exit 1
  fi
}

empty_s3_bucket_completely() {
  local bucket_name="$1"
  local delete_payload
  local object_count

  echo "S3バケットを空にします: ${bucket_name}"
  if ! aws s3api head-bucket --bucket "$bucket_name" >/dev/null 2>&1; then
    echo "S3バケットは存在しないためスキップします: ${bucket_name}"
    return
  fi

  aws s3 rm "s3://${bucket_name}" --recursive --region "$AWS_REGION"

  while true; do
    delete_payload="$(
      aws s3api list-object-versions \
        --bucket "$bucket_name" \
        --region "$AWS_REGION" \
        --max-items 1000 \
        --output json \
      | jq -c '{
          Objects: (
            [.Versions[]?, .DeleteMarkers[]?]
            | map({Key: .Key, VersionId: .VersionId})
          ),
          Quiet: true
        }'
    )"

    object_count="$(jq '.Objects | length' <<< "$delete_payload")"
    [[ "$object_count" -eq 0 ]] && break

    aws s3api delete-objects \
      --bucket "$bucket_name" \
      --region "$AWS_REGION" \
      --delete "$delete_payload" \
      > /dev/null
  done
}

delete_dynamodb_table() {
  local table_name="$1"

  [[ -z "$table_name" || "$table_name" == "null" ]] && return

  if ! aws dynamodb describe-table \
    --table-name "$table_name" \
    --region "$AWS_REGION" \
    >/dev/null 2>&1; then
    echo "DynamoDBテーブルは存在しないためスキップします: ${table_name}"
    return
  fi

  echo "DynamoDBテーブルを削除します: ${table_name}"
  aws dynamodb update-table \
    --table-name "$table_name" \
    --region "$AWS_REGION" \
    --no-deletion-protection-enabled \
    > /dev/null

  until [[ "$(
    aws dynamodb describe-table \
      --table-name "$table_name" \
      --region "$AWS_REGION" \
      --query 'Table.TableStatus' \
      --output text
  )" == "ACTIVE" ]]; do
    sleep 5
  done

  aws dynamodb delete-table \
    --table-name "$table_name" \
    --region "$AWS_REGION" \
    > /dev/null

  aws dynamodb wait table-not-exists \
    --table-name "$table_name" \
    --region "$AWS_REGION"
}

delete_s3_bucket() {
  local bucket_name="$1"

  [[ -z "$bucket_name" || "$bucket_name" == "null" ]] && return

  if ! aws s3api head-bucket --bucket "$bucket_name" >/dev/null 2>&1; then
    echo "S3バケットは存在しないためスキップします: ${bucket_name}"
    return
  fi

  empty_s3_bucket_completely "$bucket_name"
  echo "S3バケットを削除します: ${bucket_name}"
  aws s3api delete-bucket \
    --bucket "$bucket_name" \
    --region "$AWS_REGION"
}

delete_log_group() {
  local log_group_name="$1"

  [[ -z "$log_group_name" || "$log_group_name" == "null" ]] && return

  echo "CloudWatch Logsロググループを削除します: ${log_group_name}"
  aws logs delete-log-group \
    --log-group-name "$log_group_name" \
    --region "$AWS_REGION" \
    || true
}

delete_log_groups_by_prefix() {
  local prefix="$1"
  local log_group_name

  while IFS= read -r log_group_name; do
    [[ -z "$log_group_name" || "$log_group_name" == "None" ]] && continue
    delete_log_group "$log_group_name"
  done < <(
    aws logs describe-log-groups \
      --log-group-name-prefix "$prefix" \
      --region "$AWS_REGION" \
      --query 'logGroups[].logGroupName' \
      --output text \
    | tr '\t' '\n'
  )
}

delete_bedrock_knowledge_base() {
  local knowledge_base_id="$1"
  local data_source_id
  local remaining_data_sources

  [[ -z "$knowledge_base_id" || "$knowledge_base_id" == "null" ]] && return

  if ! aws bedrock-agent get-knowledge-base \
    --knowledge-base-id "$knowledge_base_id" \
    --region "$AWS_REGION" \
    >/dev/null 2>&1; then
    echo "Bedrock Knowledge Baseは存在しないためスキップします: ${knowledge_base_id}"
    return
  fi

  while IFS= read -r data_source_id; do
    [[ -z "$data_source_id" || "$data_source_id" == "None" ]] && continue
    echo "Bedrock Data Sourceを削除します: ${data_source_id}"
    aws bedrock-agent delete-data-source \
      --knowledge-base-id "$knowledge_base_id" \
      --data-source-id "$data_source_id" \
      --region "$AWS_REGION" \
      > /dev/null \
      || true
  done < <(
    aws bedrock-agent list-data-sources \
      --knowledge-base-id "$knowledge_base_id" \
      --region "$AWS_REGION" \
      --query 'dataSourceSummaries[].dataSourceId' \
      --output text \
    | tr '\t' '\n'
  )

  for _ in {1..60}; do
    remaining_data_sources="$(
      aws bedrock-agent list-data-sources \
        --knowledge-base-id "$knowledge_base_id" \
        --region "$AWS_REGION" \
        --query 'length(dataSourceSummaries)' \
        --output text 2>/dev/null || printf '0'
    )"
    [[ "$remaining_data_sources" == "0" ]] && break
    sleep 5
  done

  echo "Bedrock Knowledge Baseを削除します: ${knowledge_base_id}"
  aws bedrock-agent delete-knowledge-base \
    --knowledge-base-id "$knowledge_base_id" \
    --region "$AWS_REGION" \
    > /dev/null \
    || true
}

delete_bedrock_knowledge_bases_by_name() {
  local knowledge_base_name="$1"
  local knowledge_base_id

  while IFS= read -r knowledge_base_id; do
    [[ -z "$knowledge_base_id" || "$knowledge_base_id" == "None" ]] && continue
    delete_bedrock_knowledge_base "$knowledge_base_id"
  done < <(
    aws bedrock-agent list-knowledge-bases \
      --region "$AWS_REGION" \
      --query "knowledgeBaseSummaries[?name=='${knowledge_base_name}'].knowledgeBaseId" \
      --output text \
    | tr '\t' '\n'
  )
}

delete_aoss_collection() {
  local collection_name="$1"
  local collection_id

  [[ -z "$collection_name" || "$collection_name" == "null" ]] && return

  collection_id="$(
    aws opensearchserverless list-collections \
      --region "$AWS_REGION" \
      --query "collectionSummaries[?name=='${collection_name}'].id | [0]" \
      --output text
  )"

  if [[ -z "$collection_id" || "$collection_id" == "None" ]]; then
    echo "OpenSearch Serverless Collectionは存在しないためスキップします: ${collection_name}"
    return
  fi

  echo "OpenSearch Serverless Collectionを削除します: ${collection_name}"
  aws opensearchserverless delete-collection \
    --id "$collection_id" \
    --region "$AWS_REGION" \
    > /dev/null \
    || true

  for _ in {1..120}; do
    collection_id="$(
      aws opensearchserverless list-collections \
        --region "$AWS_REGION" \
        --query "collectionSummaries[?name=='${collection_name}'].id | [0]" \
        --output text
    )"
    [[ -z "$collection_id" || "$collection_id" == "None" ]] && break
    sleep 5
  done
}

delete_aoss_policy() {
  local policy_type="$1"
  local policy_name="$2"

  [[ -z "$policy_name" || "$policy_name" == "null" ]] && return

  echo "OpenSearch Serverless ${policy_type} policyを削除します: ${policy_name}"
  aws opensearchserverless delete-security-policy \
    --type "$policy_type" \
    --name "$policy_name" \
    --region "$AWS_REGION" \
    > /dev/null \
    || true
}

delete_aoss_access_policy() {
  local policy_name="$1"

  [[ -z "$policy_name" || "$policy_name" == "null" ]] && return

  echo "OpenSearch Serverless access policyを削除します: ${policy_name}"
  aws opensearchserverless delete-access-policy \
    --type data \
    --name "$policy_name" \
    --region "$AWS_REGION" \
    > /dev/null \
    || true
}

delete_tagged_stack_resources() {
  local resource_arn
  local resource_id
  local log_group_name
  local bucket_name
  local collection_id

  while IFS= read -r resource_arn; do
    [[ -z "$resource_arn" || "$resource_arn" == "None" ]] && continue

    case "$resource_arn" in
      arn:aws:cognito-idp:*:*:userpool/*)
        resource_id="${resource_arn##*/}"
        if aws cognito-idp describe-user-pool \
          --user-pool-id "$resource_id" \
          --region "$AWS_REGION" \
          >/dev/null 2>&1; then
          echo "タグ付きCognito User Poolを削除します: ${resource_id}"
          aws cognito-idp delete-user-pool \
            --user-pool-id "$resource_id" \
            --region "$AWS_REGION" \
            || true
        fi
        ;;
      arn:aws:logs:*:*:log-group:*)
        log_group_name="${resource_arn#*:log-group:}"
        log_group_name="${log_group_name%%:*}"
        delete_log_group "$log_group_name"
        ;;
      arn:aws:dynamodb:*:*:table/*)
        resource_id="${resource_arn##*/}"
        delete_dynamodb_table "$resource_id"
        ;;
      arn:aws:s3:::*)
        bucket_name="${resource_arn#arn:aws:s3:::}"
        bucket_name="${bucket_name%%/*}"
        delete_s3_bucket "$bucket_name"
        ;;
      arn:aws:aoss:*:*:collection/*)
        collection_id="${resource_arn##*/}"
        if aws opensearchserverless batch-get-collection \
          --ids "$collection_id" \
          --region "$AWS_REGION" \
          --query 'collectionDetails[0].id' \
          --output text >/dev/null 2>&1; then
          echo "タグ付きOpenSearch Serverless Collectionを削除します: ${collection_id}"
          aws opensearchserverless delete-collection \
            --id "$collection_id" \
            --region "$AWS_REGION" \
            > /dev/null \
            || true
        fi
        ;;
      *)
        echo "タグ付きリソースの自動削除対象外です: ${resource_arn}"
        ;;
    esac
  done < <(
    aws resourcegroupstaggingapi get-resources \
      --region "$AWS_REGION" \
      --tag-filters Key=aws:cloudformation:stack-name,Values="$STACK_NAME" \
      --query 'ResourceTagMappingList[].ResourceARN' \
      --output text 2>/dev/null \
    | tr '\t' '\n'
  )
}

remaining_resource_lines() {
  local lines=()
  local value

  for value in "$CHAT_TABLE_NAME" "$LIBRARY_TABLE_NAME"; do
    if [[ -n "$value" && "$value" != "null" ]] \
      && aws dynamodb describe-table --table-name "$value" --region "$AWS_REGION" >/dev/null 2>&1; then
      lines+=("DynamoDB: ${value}")
    fi
  done

  for value in "$FRONTEND_BUCKET_NAME" "$RAG_SOURCE_BUCKET_NAME"; do
    if [[ -n "$value" && "$value" != "null" ]] \
      && aws s3api head-bucket --bucket "$value" >/dev/null 2>&1; then
      lines+=("S3: ${value}")
    fi
  done

  if [[ -n "$USER_POOL_ID" && "$USER_POOL_ID" != "null" ]] \
    && aws cognito-idp describe-user-pool --user-pool-id "$USER_POOL_ID" --region "$AWS_REGION" >/dev/null 2>&1; then
    lines+=("Cognito User Pool: ${USER_POOL_ID}")
  fi

  if [[ -n "$BEDROCK_KNOWLEDGE_BASE_ID" && "$BEDROCK_KNOWLEDGE_BASE_ID" != "null" ]] \
    && aws bedrock-agent get-knowledge-base --knowledge-base-id "$BEDROCK_KNOWLEDGE_BASE_ID" --region "$AWS_REGION" >/dev/null 2>&1; then
    lines+=("Bedrock Knowledge Base: ${BEDROCK_KNOWLEDGE_BASE_ID}")
  fi

  while IFS= read -r value; do
    [[ -z "$value" || "$value" == "None" ]] && continue
    lines+=("OpenSearch Serverless Collection: ${value}")
  done < <(
    aws opensearchserverless list-collections \
      --region "$AWS_REGION" \
      --query "collectionSummaries[?starts_with(name, '${RESOURCE_NAME_PREFIX}')].name" \
      --output text \
    | tr '\t' '\n'
  )

  while IFS= read -r value; do
    [[ -z "$value" || "$value" == "None" ]] && continue
    lines+=("CloudWatch Logs: ${value}")
  done < <(
    aws logs describe-log-groups \
      --log-group-name-prefix "/aws/ecs/containerinsights/${STACK_NAME}" \
      --region "$AWS_REGION" \
      --query 'logGroups[].logGroupName' \
      --output text \
    | tr '\t' '\n'
  )
  while IFS= read -r value; do
    [[ -z "$value" || "$value" == "None" ]] && continue
    lines+=("CloudWatch Logs: ${value}")
  done < <(
    aws logs describe-log-groups \
      --log-group-name-prefix "/aws/lambda/${STACK_NAME}" \
      --region "$AWS_REGION" \
      --query 'logGroups[].logGroupName' \
      --output text \
    | tr '\t' '\n'
  )

  while IFS= read -r value; do
    [[ -z "$value" || "$value" == "None" ]] && continue
    lines+=("ECS Cluster: ${value}")
  done < <(
    aws ecs list-clusters \
      --region "$AWS_REGION" \
      --query "clusterArns[?contains(@, '${STACK_NAME}') || contains(@, '${RESOURCE_NAME_PREFIX}')]" \
      --output text \
    | tr '\t' '\n'
  )

  while IFS= read -r value; do
    [[ -z "$value" || "$value" == "None" ]] && continue
    lines+=("VPC: ${value}")
  done < <(
    aws ec2 describe-vpcs \
      --region "$AWS_REGION" \
      --filters "Name=tag:Name,Values=*${STACK_NAME}*,*${RESOURCE_NAME_PREFIX}*" \
      --query 'Vpcs[].VpcId' \
      --output text \
    | tr '\t' '\n'
  )

  while IFS= read -r value; do
    [[ -z "$value" || "$value" == "None" ]] && continue
    lines+=("ELBv2 Load Balancer: ${value}")
  done < <(
    aws elbv2 describe-load-balancers \
      --region "$AWS_REGION" \
      --query "LoadBalancers[?contains(LoadBalancerName, '${STACK_NAME}') || contains(LoadBalancerName, '${RESOURCE_NAME_PREFIX}')].LoadBalancerName" \
      --output text \
    | tr '\t' '\n'
  )

  if remaining_tagged_resources="$(
    aws resourcegroupstaggingapi get-resources \
      --region "$AWS_REGION" \
      --tag-filters Key=aws:cloudformation:stack-name,Values="$STACK_NAME" \
      --query 'ResourceTagMappingList[].ResourceARN' \
      --output text 2>/dev/null
  )" && [[ -n "$remaining_tagged_resources" ]]; then
    lines+=("タグ付きリソース: ${remaining_tagged_resources}")
  fi

  if [[ "${#lines[@]}" -gt 0 ]]; then
    printf '%s\n' "${lines[@]}"
  fi
}

audit_deleted_resources() {
  local remaining_lines

  echo
  echo "削除結果を監査します"

  if aws cloudformation describe-stacks \
    --stack-name "$STACK_NAME" \
    --region "$AWS_REGION" \
    >/dev/null 2>&1; then
    echo "スタックがまだ存在します: ${STACK_NAME}" >&2
    exit 1
  fi

  remaining_lines="$(remaining_resource_lines)"
  if [[ -n "$remaining_lines" ]]; then
    echo "PaperBuddy関連リソースが残っています:" >&2
    printf '%s\n' "$remaining_lines" >&2
    exit 1
  fi

  echo "PaperBuddy本体リソースの削除を確認しました"
}

require_command aws
require_command jq

if [[ ! -f "$ENV_FILE" ]]; then
  echo "infra設定ファイルが見つかりません: ${ENV_FILE}" >&2
  echo "infra/.env.example を infra/.env にコピーして値を設定してください。" >&2
  exit 1
fi

STACK_NAME="$(read_env_value STACK_NAME)"
AWS_REGION="$(read_env_value AWS_REGION)"

aws cloudformation describe-stacks \
  --stack-name "$STACK_NAME" \
  --region "$AWS_REGION" \
  --output json \
  > "$STACK_SNAPSHOT_FILE" 2>/dev/null \
  || printf '{"Stacks":[{"Outputs":[]}]}\n' > "$STACK_SNAPSHOT_FILE"

if aws cloudformation list-stack-resources \
  --stack-name "$STACK_NAME" \
  --region "$AWS_REGION" \
  --output json \
  > "$STACK_RESOURCES_FILE" 2>/dev/null; then
  stack_exists="true"
else
  printf '{"StackResourceSummaries":[]}\n' > "$STACK_RESOURCES_FILE"
  stack_exists="false"
fi

CHAT_TABLE_NAME="$(output_value ChatTableName)"
LIBRARY_TABLE_NAME="$(output_value LibraryTableName)"
FRONTEND_BUCKET_NAME="$(output_value FrontendBucketName)"
RAG_SOURCE_BUCKET_NAME="$(output_value RagSourceBucketName)"
USER_POOL_ID="$(output_value UserPoolId)"
BEDROCK_KNOWLEDGE_BASE_ID="$(output_value BedrockKnowledgeBaseId)"
BEDROCK_DATA_SOURCE_ID="$(output_value BedrockDataSourceId)"
AOSS_COLLECTION_NAME="${RESOURCE_NAME_PREFIX}-kb"
AOSS_ACCESS_POLICY_NAME="${RESOURCE_NAME_PREFIX}-kb-access"
AOSS_ENCRYPTION_POLICY_NAME="${RESOURCE_NAME_PREFIX}-kb-encryption"
AOSS_NETWORK_POLICY_NAME="${RESOURCE_NAME_PREFIX}-kb-network"
LOG_GROUP_NAMES=()
while IFS= read -r log_group_name; do
  [[ -z "$log_group_name" ]] && continue
  LOG_GROUP_NAMES+=("$log_group_name")
done < <(stack_resource_ids_by_type "AWS::Logs::LogGroup")

echo "以下のPaperBuddy本体AWSリソースを削除します。削除後は復元できません。"
echo "AWSアカウント:"
aws sts get-caller-identity
echo
printf 'AWS_REGION=%s\n' "$AWS_REGION"
printf 'STACK_NAME=%s\n' "$STACK_NAME"
printf 'STACK_EXISTS=%s\n' "$stack_exists"
printf 'CHAT_TABLE_NAME=%s\n' "$CHAT_TABLE_NAME"
printf 'LIBRARY_TABLE_NAME=%s\n' "$LIBRARY_TABLE_NAME"
printf 'FRONTEND_BUCKET_NAME=%s\n' "$FRONTEND_BUCKET_NAME"
printf 'RAG_SOURCE_BUCKET_NAME=%s\n' "$RAG_SOURCE_BUCKET_NAME"
printf 'USER_POOL_ID=%s\n' "$USER_POOL_ID"
printf 'BEDROCK_KNOWLEDGE_BASE_ID=%s\n' "$BEDROCK_KNOWLEDGE_BASE_ID"
printf 'BEDROCK_DATA_SOURCE_ID=%s\n' "$BEDROCK_DATA_SOURCE_ID"
printf 'AOSS_COLLECTION_NAME=%s\n' "$AOSS_COLLECTION_NAME"
printf 'LOG_GROUP_NAMES=%s\n' "${LOG_GROUP_NAMES[*]:-}"
echo
echo "CDK bootstrap資産は削除しません。必要な場合は別途 mise run infra:destroy:bootstrap:dev を実行してください。"
echo
read -r -p "削除を続行するにはスタック名 ${STACK_NAME} を入力してください: " confirmation

if [[ "$confirmation" != "$STACK_NAME" ]]; then
  echo "入力が一致しないため削除を中止しました" >&2
  exit 1
fi

if [[ "$stack_exists" == "true" ]]; then
  echo "CloudFormationスタックを削除します: ${STACK_NAME}"
  aws cloudformation delete-stack \
    --stack-name "$STACK_NAME" \
    --region "$AWS_REGION"

  aws cloudformation wait stack-delete-complete \
    --stack-name "$STACK_NAME" \
    --region "$AWS_REGION"
else
  echo "CloudFormationスタックは存在しないためスキップします: ${STACK_NAME}"
fi

delete_bedrock_knowledge_base "$BEDROCK_KNOWLEDGE_BASE_ID"
delete_bedrock_knowledge_bases_by_name "$RESOURCE_NAME_PREFIX"
delete_aoss_collection "$AOSS_COLLECTION_NAME"
delete_aoss_access_policy "$AOSS_ACCESS_POLICY_NAME"
delete_aoss_policy encryption "$AOSS_ENCRYPTION_POLICY_NAME"
delete_aoss_policy network "$AOSS_NETWORK_POLICY_NAME"
delete_dynamodb_table "$CHAT_TABLE_NAME"
delete_dynamodb_table "$LIBRARY_TABLE_NAME"
delete_s3_bucket "$FRONTEND_BUCKET_NAME"
delete_s3_bucket "$RAG_SOURCE_BUCKET_NAME"

if [[ -n "$USER_POOL_ID" && "$USER_POOL_ID" != "null" ]]; then
  echo "Cognito User Poolを削除します: ${USER_POOL_ID}"
  aws cognito-idp delete-user-pool \
    --user-pool-id "$USER_POOL_ID" \
    --region "$AWS_REGION" \
    || true
fi

for log_group_name in "${LOG_GROUP_NAMES[@]:-}"; do
  delete_log_group "$log_group_name"
done
delete_log_groups_by_prefix "/aws/ecs/containerinsights/${STACK_NAME}"
delete_log_groups_by_prefix "/aws/lambda/${STACK_NAME}"
delete_tagged_stack_resources

audit_deleted_resources

echo
echo "PaperBuddy本体AWSリソースを削除しました。"
