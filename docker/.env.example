# ローカル開発環境用の環境変数。
# バックエンドとフロントエンドは、ここで指定したAWS上のローカル開発用Cognitoを使用する。
# AWS認証情報は記載せず、Cognitoの識別子だけを設定する。

AWS_REGION=ap-northeast-1
LOG_LEVEL=INFO

# local: 疑似LLM、aws: AWS Bedrock Knowledge Base
CHAT_GENERATION_MODE=local

# CHAT_GENERATION_MODE=aws の場合だけ設定する。
BEDROCK_KNOWLEDGE_BASE_ID=
BEDROCK_MODEL_ARN=

COGNITO_USER_POOL_ID=ap-northeast-1_replace-with-user-pool-id
COGNITO_USER_POOL_CLIENT_ID=replace-with-user-pool-client-id

VITE_API_BASE_URL=/api
VITE_COGNITO_USER_POOL_ID=ap-northeast-1_replace-with-user-pool-id
VITE_COGNITO_USER_POOL_CLIENT_ID=replace-with-user-pool-client-id
