# AWS認証情報は記載せず、各端末でログイン済みのAWS CLI認証を使用する。
AWS_REGION=ap-northeast-1

CHAT_INFRASTRUCTURE_MODE=aws
DYNAMODB_CHAT_TABLE_NAME=paperbuddy-dev-chat
DYNAMODB_LIBRARY_TABLE_NAME=paperbuddy-dev-library

# These values are identifiers, not credentials.
BEDROCK_KNOWLEDGE_BASE_ID=replace-with-knowledge-base-id
BEDROCK_MODEL_ARN=arn:aws:bedrock:ap-northeast-1::foundation-model/replace-with-model-id
COGNITO_USER_POOL_ID=ap-northeast-1_replace-with-user-pool-id
COGNITO_USER_POOL_CLIENT_ID=replace-with-user-pool-client-id

# Local infrastructure mode only.
# DYNAMODB_ENDPOINT_URL=http://localhost:8001
# SIMULATED_LLM_DELAY_SECONDS=2
