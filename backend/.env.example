# Name of a profile configured in ~/.aws/config or ~/.aws/credentials.
AWS_PROFILE=default
AWS_REGION=ap-northeast-1

# Use "in_memory" for local development or "dynamodb" for persistent storage.
CHAT_REPOSITORY_TYPE=in_memory
DYNAMODB_CHAT_TABLE_NAME=replace-with-chat-table-name

# These values are identifiers, not credentials.
BEDROCK_KNOWLEDGE_BASE_ID=replace-with-knowledge-base-id
BEDROCK_MODEL_ARN=arn:aws:bedrock:ap-northeast-1::foundation-model/replace-with-model-id
